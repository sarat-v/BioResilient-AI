# Copy to project root as `.env` and fill in values.
#   cp .env.example .env
# Before running the API or Nextflow locally:
#   set -a && source .env && set +a
#   # or: export $(grep -v '^#' .env | xargs)
#
# .env is gitignored — never commit real secrets.

# --- AWS CLI (local Mac: ECR login, S3 sync, RDS tools) ---
AWS_PROFILE=seqera-runner
AWS_REGION=ap-south-1

# --- PostgreSQL (cloud / RDS) ---
RDS_HOST=bioresilient.xxxxxxxx.ap-south-1.rds.amazonaws.com
# Full URL for Nextflow / apps that need a connection string:
# DATABASE_URL=postgresql://bioresilient:YOUR_PASSWORD@${RDS_HOST}:5432/bioresilient?sslmode=require
#
# Local Mac cannot reach a private RDS endpoint directly. Use one of:
#   1) SSM tunnel (see scripts/rds_port_forward.sh; needs session-manager-plugin + ssm:StartSession):
#        export RDS_TUNNEL_EC2_ID=i-xxxxxxxx   # EC2 in same VPC as RDS
#        bash scripts/rds_port_forward.sh      # forwards localhost:5433 -> RDS:5432
#      Then: DATABASE_URL=...postgresql://...@127.0.0.1:5433/...
#   2) scripts/sync_rds_to_local.sh — opens RDS SG to your current public IP (only if
#      RDS is reachable from the internet for that endpoint; private-only RDS needs a tunnel).
#   3) SSH port-forward (typical “old” path — EC2 opens TCP to RDS; see scripts/rds_ssh_tunnel.sh):
#        export EC2_HOST=... EC2_KEY=~/.ssh/your.pem
#        bash scripts/rds_ssh_tunnel.sh
#      Then DATABASE_URL with 127.0.0.1:5433 (same as scripts/pull_aws_data.sh EC2 pattern).
#   4) No live SQL from laptop: scripts/pull_aws_data.sh — SSH to EC2, pg_dump on EC2 to RDS,
#      upload dump to S3, download locally; restore into local Postgres and use deployment: local.
#   Same SSM / SG patterns are at the top of scripts/migrate_and_rerun.sh (Option A / B).
# RDS_TUNNEL_EC2_ID=
# RDS_LOCAL_PORT=5433

# --- Seqera Platform (FastAPI pipeline control + Tower) ---
# Same token as cloud.seqera.io → User menu → Access tokens
SEQERA_API_TOKEN=
# From user-info API or Settings URL
SEQERA_WORKSPACE_ID=
# Launchpad pipeline page URL contains the numeric ID
SEQERA_PIPELINE_ID=
# Optional — only for prettier "View in Seqera" links
# SEQERA_ORG_NAME=
# SEQERA_WORKSPACE_NAME=

# Nextflow subprocess mode (when using Tower monitor from the API)
NEXTFLOW_PROFILE=aws
