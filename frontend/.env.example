# Vercel Frontend Environment Variables
# Copy these to your Vercel project settings at https://vercel.com/dashboard

# API endpoint for the BioResilient backend
# Example for local dev: http://localhost:8000
# Example for remote (office PC): https://your-office-pc-ip:8000 or via ngrok/reverse proxy
VITE_API_BASE_URL=https://api.bioresilient.dev

# Optional: For development, you can use localhost
# VITE_API_BASE_URL=http://localhost:8000
