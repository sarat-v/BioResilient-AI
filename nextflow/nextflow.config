/*
 * BioResilient AI v2 — Nextflow Configuration
 *
 * Run with:
 *   nextflow run nextflow/main.nf -profile local
 *   nextflow run nextflow/main.nf -profile aws   --from step6
 *   nextflow run nextflow/main.nf -profile gcp
 */

params {
    phenotype       = 'cancer_resistance'
    from_step       = 'step1'
    until           = 'step15'    // inclusive end step; override with --until stepN
    db_url          = null         // overridden per profile
    storage_root    = null         // overridden per profile
    ncbi_api_key    = null
    s3_bucket       = 'bioresilient-data'
    gcs_bucket      = 'bioresilient-data'

    // PAML scatter tuning (replaces HyPhy — much faster and lighter)
    paml_max_forks   = 64          // 64 concurrent tasks × 4 vCPU = 256 vCPU (safe under 512 limit)
    paml_cpus        = 4           // 4 CPUs: 4 OGs in parallel × 1 CPU each (PAML single-threaded)
    paml_memory      = '8 GB'      // 8 GB RAM: 4 OGs × ~200 MB = well under 1 GB; headroom for large alignments
    paml_batch_size  = 20          // 20 OGs per batch → 4 OGs concurrent = up to 600s each
    // Cache key for extract_og_ids storeDir. Bump (e.g. v2) to force a fresh
    // OG list when DB state changes (new OGs scored) or batch_size changes.
    // v2: targeted rerun for 870 proxy + 381 NULL-model genes (1,251 total)
    //     after neutralizing old HyPhy/proxy p-values in evolution_score.
    paml_og_cache_key = 'v2'

    // Large-step resource defaults
    orthofinder_cpus   = 16
    orthofinder_memory = '64 GB'
    align_cpus         = 16
    align_memory       = '32 GB'
    iqtree_cpus        = 8         // IQ-TREE2 scales well; 8 vCPU cuts species-tree to ~20 min
    iqtree_memory      = '24 GB'

    // ESM-1v: targets g4dn.2xlarge (8 vCPU, 32 GB RAM, T4 16 GB VRAM) or g5.2xlarge (A10G).
    // bioresilient-gpu CE is restricted to ONLY these two 2xlarge variants —
    // larger instances (4xlarge/8xlarge) carry the same single GPU but waste CPU/RAM/cost.
    // Scatter pre-filters fully-scored genes so we only submit tasks with real work.
    esm_cpus           = 4
    esm_memory         = '20 GB'     // 20 GB: ESM-1v model ~10 GB + 10 GB headroom, fits g4dn.2xlarge
    esm_chunks         = 100         // 100 parallel GPU tasks of ~120 unscored genes each ≈ 10-15 min/task

    outdir = 'results'
}

// Container image names (short names for local; aws profile overrides with ECR URIs)
process {
    errorStrategy = { task.exitStatus in [137, 143, 255] ? 'retry' : 'terminate' }
    maxRetries    = 3

    withLabel: 'base'        { container = 'bioresilient/base:latest' }
    withLabel: 'orthofinder' { container = 'bioresilient/orthofinder:latest' }
    withLabel: 'align'       { container = 'bioresilient/align:latest' }
    withLabel: 'phylo'       { container = 'bioresilient/phylo:latest' }
    withLabel: 'hyphy'       { container = 'bioresilient/hyphy:latest' }
    withLabel: 'paml'        { container = 'bioresilient/paml:latest' }
    withLabel: 'esm'         { container = 'bioresilient/esm:latest' }
    withLabel: 'clinical'    { container = 'bioresilient/clinical:latest' }
}

profiles {

    local {
        process.executor = 'local'
        docker.enabled   = true

        params {
            db_url       = 'postgresql://localhost/bioresilient'
            storage_root = './data'
        }

        process {
            withLabel: 'hyphy' {
                maxForks = params.hyphy_max_forks
            }
        }
    }

    aws {
        process.executor = 'awsbatch'
        aws.region       = 'ap-south-1'
        // aws.batch.cliPath not needed — Wave+Fusion handles all S3 file staging

        process {
            queue = 'bioresilient-spot'

            // Override container names with full ECR URIs for AWS Batch
            withLabel: 'base'        { container = '544015794225.dkr.ecr.ap-south-1.amazonaws.com/bioresilient/base:latest' }
            withLabel: 'orthofinder' { container = '544015794225.dkr.ecr.ap-south-1.amazonaws.com/bioresilient/orthofinder:latest' }
            withLabel: 'align'       { container = '544015794225.dkr.ecr.ap-south-1.amazonaws.com/bioresilient/align:latest' }
            withLabel: 'phylo'       { container = '544015794225.dkr.ecr.ap-south-1.amazonaws.com/bioresilient/phylo:latest' }
            withLabel: 'hyphy'       { container = '544015794225.dkr.ecr.ap-south-1.amazonaws.com/bioresilient/hyphy:latest' }
            withLabel: 'paml'        { container = '544015794225.dkr.ecr.ap-south-1.amazonaws.com/bioresilient/paml:latest' }
            withLabel: 'esm'         { container = '544015794225.dkr.ecr.ap-south-1.amazonaws.com/bioresilient/esm:latest' }
            withLabel: 'clinical'    { container = '544015794225.dkr.ecr.ap-south-1.amazonaws.com/bioresilient/clinical:latest' }
        }

        params {
            // Resolved at Nextflow launch time from env vars on the submitting machine
            db_url       = "postgresql://bioresilient:${System.getenv('RDS_PASSWORD') ?: 'UNSET'}@${System.getenv('RDS_HOST') ?: 'UNSET'}/bioresilient?sslmode=require"
            storage_root = "s3://${params.s3_bucket}"
        }

        // Spot-optimized: exit codes 137 (OOM kill), 255 (spot termination)
        process {
            errorStrategy = { task.exitStatus in [137, 143, 255] ? 'retry' : 'terminate' }
            maxRetries    = 5

            // Align + nucleotide steps need 14 vCPU / 32 GB → large queue
            withLabel: 'align' {
                queue  = 'bioresilient-large'
                cpus   = params.align_cpus
                memory = params.align_memory
            }
            withLabel: 'hyphy' {
                queue  = 'bioresilient-spot'
                cpus   = params.paml_cpus
                memory = params.paml_memory
                time   = '2h'
            }
            withLabel: 'paml' {
                queue  = 'bioresilient-spot'   // 512 vCPU max → 128 concurrent 4-vCPU tasks
                cpus   = params.paml_cpus      // 4 CPUs: 4 OGs × 1 CPU each (PAML single-threaded)
                memory = params.paml_memory    // 8 GB is plenty for PAML
                time   = '3h'                  // 20 OGs × max 600s each / 4 parallel = ~50 min; 3h is safe
            }
            // IQ-TREE needs 8 vCPU / 24 GB → large queue
            withLabel: 'phylo' {
                queue  = 'bioresilient-large'
                cpus   = params.iqtree_cpus
                memory = params.iqtree_memory
            }
            // ESM-1v: bioresilient-gpu CE restricted to g4dn.2xlarge + g5.2xlarge only.
            // Both have exactly 1 GPU (T4/A10G), 8 vCPU, 32 GB RAM — right-sized for ESM-1v.
            // 100 parallel chunks × one GPU each; each chunk runs ~10-15 min.
            withLabel: 'esm' {
                queue       = 'bioresilient-gpu'
                cpus        = params.esm_cpus
                memory      = params.esm_memory
                accelerator = 1
            }
            withLabel: 'orthofinder' {
                queue  = 'bioresilient-large'
                cpus   = params.orthofinder_cpus
                memory = params.orthofinder_memory
            }
        }

        wave.enabled    = true
        fusion.enabled  = true
    }

    gcp {
        process.executor = 'google-batch'
        google.region    = 'us-central1'
        google.project   = 'bioresilient'

        params {
            db_url       = "postgresql://bioresilient:\${CLOUDSQL_PASSWORD}@\${CLOUDSQL_HOST}/bioresilient"
            storage_root = "gs://${params.gcs_bucket}"
        }

        process {
            machineType = 'n2-standard-4'
            errorStrategy = { task.exitStatus in [137, 143, 255] ? 'retry' : 'terminate' }
            maxRetries    = 5

            withLabel: 'hyphy' {
                machineType = 'n2-standard-2'
                spot = true
            }
            withLabel: 'esm' {
                machineType  = 'n1-standard-4'
                spot         = true
                accelerator  = [request: 1, type: 'nvidia-tesla-t4']
            }
            withLabel: 'orthofinder' {
                machineType = 'n2-standard-16'
                spot = true
            }
        }

        wave.enabled   = true
        fusion.enabled = true
    }

    seqera {
        tower {
            enabled   = true
            endpoint  = 'https://api.cloud.seqera.io'
            // Accept either TOWER_ACCESS_TOKEN (Nextflow native) or SEQERA_API_TOKEN (our env var)
            accessToken = System.getenv('TOWER_ACCESS_TOKEN') ?: System.getenv('SEQERA_API_TOKEN')
            workspaceId = (System.getenv('TOWER_WORKSPACE_ID')?.trim() ?: System.getenv('SEQERA_WORKSPACE_ID')?.trim()) ?: null
        }
    }
}

// Nextflow reporting
timeline {
    enabled   = true
    file      = "${params.outdir}/timeline.html"
    overwrite = true
}
report {
    enabled   = true
    file      = "${params.outdir}/report.html"
    overwrite = true
}
trace {
    enabled   = true
    file      = "${params.outdir}/trace.txt"
    overwrite = true
}

manifest {
    name            = 'BioResilient-AI'
    author          = 'BioResilient Team'
    description     = 'Convergent evolution pipeline for cancer resistance gene discovery'
    mainScript      = 'main.nf'
    nextflowVersion = '>=24.04'
    version         = '2.0.0'
}
