# Copy the contents you need into ~/.aws/credentials on your Mac.
#   mkdir -p ~/.aws
#   cp config/aws-credentials.example ~/.aws/credentials
#   chmod 600 ~/.aws/credentials
# Then edit and replace YOUR_* placeholders with real keys from IAM.
#
# Never commit ~/.aws/credentials or real keys to git.

[seqera-runner]
aws_access_key_id = YOUR_SEQERA_RUNNER_ACCESS_KEY_ID
aws_secret_access_key = YOUR_SEQERA_RUNNER_SECRET_ACCESS_KEY

# Optional: second profile for another IAM user
# [bioresilient-cli]
# aws_access_key_id = ...
# aws_secret_access_key = ...

# Optional: default profile (when AWS_PROFILE is unset)
# [default]
# aws_access_key_id = ...
# aws_secret_access_key = ...
